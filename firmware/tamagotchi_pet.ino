/*
 * Tamagotchi with Custom Animated Sprites
 * - 3 Growth Stages: Egg → Child → Adult
 * - Each stage has 2-frame idle animation
 * - Send "TASK_DONE" via BLE to complete tasks and evolve
 *
 * 🔥 SPI MODE with 7-pin OLED
 * Pins: SCK=18, MOSI=23, DC=4, RESET=14, CS=5
 *
 * MODIFICATIONS:
 * - Sprites scaled 2x (32→64 px)
 * - Only task count shown in top-right corner
 * - SPRITES ARE INVERTED (black on white rectangle)
 * - Background stays black, text stays white
 */

#include <Wire.h>
#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <BLEDevice.h>
#include <BLEServer.h>
#include <BLEUtils.h>
#include <BLE2902.h>

// ============ Display Configuration ============
#define SCREEN_WIDTH  128
#define SCREEN_HEIGHT 64

// ---------- SPI Pin Definitions ----------
#define OLED_MOSI   23
#define OLED_CLK    18
#define OLED_DC     4
#define OLED_RESET  14
#define OLED_CS     5

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &SPI, OLED_DC, OLED_RESET, OLED_CS, 4000000);

